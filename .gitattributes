# Normalize line endings: store as LF in the repo, check out as LF everywhere.
# Kills the recurring "LF will be replaced by CRLF" churn that bloats diffs.
* text=auto eol=lf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.mp3 binary
